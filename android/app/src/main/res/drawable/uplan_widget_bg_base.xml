<?xml version="1.0" encoding="utf-8"?>
<!-- White rounded base for the widget background. Tinted to the user's chosen
     colour (setColorFilter) and faded (setImageAlpha) at runtime, so the
     rounded corners are preserved while colour + transparency are adjustable. -->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">
    <solid android:color="#FFFFFFFF" />
    <corners android:radius="20dp" />
</shape>
