<?xml version="1.0" encoding="utf-8"?>
<!-- Collapsed body of the Live dashboard notification. Rendered inside the
     system notification frame (DecoratedCustomViewStyle), so no background —
     the shade supplies it and keeps light/dark mode correct. Only
     RemoteViews-supported views allowed (LinearLayout, TextView, ...). -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical">

    <TextView
        android:id="@+id/live_title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textAppearance="@style/TextAppearance.Compat.Notification.Title"
        android:textSize="14sp"
        android:maxLines="1"
        android:ellipsize="end" />

    <TextView
        android:id="@+id/live_sub"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="2dp"
        android:textAppearance="@style/TextAppearance.Compat.Notification.Info"
        android:textSize="12sp"
        android:maxLines="1"
        android:ellipsize="end" />
</LinearLayout>
