<?xml version="1.0" encoding="utf-8"?>
<!-- One day cell in the month-grid widget: day number + up to 3 priority dots.
     Background colour is set at runtime for shift days. -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/cell_root"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:minHeight="40dp"
    android:orientation="vertical"
    android:gravity="center"
    android:padding="2dp">

    <TextView
        android:id="@+id/cell_day"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textColor="#FFFFFFFF"
        android:textSize="13sp" />

    <!-- Rotation label (ICU1, ER, …) — small, under the day number. -->
    <TextView
        android:id="@+id/cell_rot"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textSize="8sp"
        android:maxLines="1"
        android:ellipsize="end"
        android:textColor="#FFFFB347"
        android:visibility="gone" />

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <TextView android:id="@+id/cell_dot1" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="•" android:textSize="11sp" android:visibility="gone" />
        <TextView android:id="@+id/cell_dot2" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="•" android:textSize="11sp" android:paddingStart="1dp" android:visibility="gone" />
        <TextView android:id="@+id/cell_dot3" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="•" android:textSize="11sp" android:paddingStart="1dp" android:visibility="gone" />
    </LinearLayout>
</LinearLayout>
