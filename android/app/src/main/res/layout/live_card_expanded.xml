<?xml version="1.0" encoding="utf-8"?>
<!-- Expanded body of the Live dashboard notification: header line, the
     current slideshow card, and the ◀ 3/7 ▶ paging controls. Buttons must
     live here — collapsed notifications have no room for touch targets. -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical">

    <!-- Today glance header -->
    <TextView
        android:id="@+id/live_exp_header"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textAppearance="@style/TextAppearance.Compat.Notification.Info"
        android:textSize="11sp"
        android:maxLines="1"
        android:ellipsize="end" />

    <!-- Current card: accent dot + title/sub -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <TextView
            android:id="@+id/live_exp_dot"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="●"
            android:textSize="14sp"
            android:layout_marginEnd="8dp" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/live_exp_title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textAppearance="@style/TextAppearance.Compat.Notification.Title"
                android:textSize="14sp"
                android:maxLines="1"
                android:ellipsize="end" />

            <TextView
                android:id="@+id/live_exp_sub"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textAppearance="@style/TextAppearance.Compat.Notification.Info"
                android:textSize="12sp"
                android:maxLines="1"
                android:ellipsize="end" />
        </LinearLayout>
    </LinearLayout>

    <!-- Paging controls -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <TextView
            android:id="@+id/live_prev"
            android:layout_width="48dp"
            android:layout_height="36dp"
            android:gravity="center"
            android:text="‹"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textAppearance="@style/TextAppearance.Compat.Notification.Title" />

        <TextView
            android:id="@+id/live_pos"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:minWidth="44dp"
            android:gravity="center"
            android:textAppearance="@style/TextAppearance.Compat.Notification.Info"
            android:textSize="12sp" />

        <TextView
            android:id="@+id/live_next"
            android:layout_width="48dp"
            android:layout_height="36dp"
            android:gravity="center"
            android:text="›"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textAppearance="@style/TextAppearance.Compat.Notification.Title" />

        <!-- Pushes the card actions to the right edge. RemoteViews only
             inflates whitelisted widgets — a plain <View> spacer crashes
             (BadForegroundServiceNotificationException), so use an empty
             TextView instead. -->
        <TextView
            android:layout_width="0dp"
            android:layout_height="1dp"
            android:layout_weight="1" />

        <TextView
            android:id="@+id/live_snooze"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:gravity="center"
            android:paddingStart="10dp"
            android:paddingEnd="10dp"
            android:text="Snooze"
            android:textSize="13sp"
            android:textAppearance="@style/TextAppearance.Compat.Notification.Info" />

        <TextView
            android:id="@+id/live_done"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:gravity="center"
            android:paddingStart="10dp"
            android:paddingEnd="12dp"
            android:text="✓ Done"
            android:textSize="13sp"
            android:textStyle="bold"
            android:textAppearance="@style/TextAppearance.Compat.Notification.Title" />
    </LinearLayout>
</LinearLayout>
